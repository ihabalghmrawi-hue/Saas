# ─── Supabase ────────────────────────────────────────────────────────────────
# Same project used by both financeapp (Vercel) and finance-saas-admin (local)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Super Admin ──────────────────────────────────────────────────────────────
# Comma-separated emails that have access to /admin panel
SUPER_ADMIN_EMAILS=admin@example.com

# ─── App URLs ─────────────────────────────────────────────────────────────────
# Local dev: http://localhost:3000  |  Production: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=FinanceApp

# ─── Defaults ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CURRENCY_DEFAULT=SAR
NEXT_PUBLIC_LANGUAGE_DEFAULT=ar
